      <!-- ================================================================ -->
      <!--                      gRPC  THREAD GROUP                          -->
      <!--  Requer shared-core-0.0.1-SNAPSHOT.jar em $JMETER_HOME/lib/ext  -->
      <!-- ================================================================ -->
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup"
                   testname="[gRPC] ${USERS} usuários" enabled="true">
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController"
                     guiclass="LoopControlPanel" testclass="LoopController" enabled="true">
          <boolProp name="LoopController.continue_forever">true</boolProp>
          <intProp name="LoopController.loops">-1</intProp>
        </elementProp>
        <stringProp name="ThreadGroup.num_threads">${USERS}</stringProp>
        <stringProp name="ThreadGroup.ramp_time">${RAMP_UP}</stringProp>
        <boolProp name="ThreadGroup.scheduler">true</boolProp>
        <stringProp name="ThreadGroup.duration">${DURATION}</stringProp>
        <stringProp name="ThreadGroup.delay">0</stringProp>
      </ThreadGroup>
      <hashTree>

        <OnceOnlyController guiclass="OnceOnlyControllerGui"
                            testclass="OnceOnlyController"
                            testname="Setup — Criar contas" enabled="true"/>
        <hashTree>
          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler"
                         testname="gRPC — createAccount A" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="script">
def host = vars.get("HOST")
def port = vars.get("GRPC_PORT") as int
def threadNum = ctx.getThreadNum()
def accountId = "grpc-${threadNum}-a"

try {
    Class.forName("br.ufrn.pdist.shared.transport.grpc.v1.TransportGatewayGrpc")
} catch (ClassNotFoundException e) {
    log.warn("[gRPC] shared-core JAR não encontrado em lib/ext — pulando")
    SampleResult.setResponseCode("200")
    SampleResult.setResponseData("SKIPPED - adicionar shared-core-0.0.1-SNAPSHOT.jar em lib/ext", "UTF-8")
    SampleResult.setSuccessful(true)
    return
}

def channelKey = "grpc_ch_${threadNum}"
def channel = vars.getObject(channelKey)
if (channel == null || channel.isShutdown()) {
    channel = io.grpc.ManagedChannelBuilder.forAddress(host, port).usePlaintext().build()
    vars.putObject(channelKey, channel)
}

try {
    def stub = br.ufrn.pdist.shared.transport.grpc.v1.TransportGatewayGrpc
        .newBlockingStub(channel)
        .withDeadlineAfter(5000, java.util.concurrent.TimeUnit.MILLISECONDS)

    def payload = com.google.protobuf.Struct.newBuilder()
        .putFields("accountId",   com.google.protobuf.Value.newBuilder().setStringValue(accountId).build())
        .putFields("initialBalance", com.google.protobuf.Value.newBuilder().setNumberValue(100000.0).build())
        .build()

    def req = br.ufrn.pdist.shared.transport.grpc.v1.TransportRequest.newBuilder()
        .setRequestId(java.util.UUID.randomUUID().toString())
        .setService("ACCOUNT")
        .setAction("createAccount")
        .setPayload(payload)
        .build()

    def resp = stub.handle(req)
    def code = resp.getStatusCode()
    SampleResult.setResponseCode(String.valueOf(code))
    SampleResult.setResponseData(resp.getMessage(), "UTF-8")
    SampleResult.setSuccessful(code == 200 || code == 409)
} catch (io.grpc.StatusRuntimeException e) {
    SampleResult.setResponseCode("503")
    SampleResult.setResponseData(e.getMessage(), "UTF-8")
    SampleResult.setSuccessful(false)
}
            </stringProp>
