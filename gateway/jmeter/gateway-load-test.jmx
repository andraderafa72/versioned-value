      <hashTree><JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="UDP Request (Groovy)" enabled="true"><stringProp name="scriptLanguage">groovy</stringProp><stringProp name="parameters"></stringProp><stringProp name="filename"></stringProp><stringProp name="script">import java.net.DatagramPacket
import java.net.DatagramSocket
import java.net.InetAddress
def host = vars.get('host')
def port = Integer.parseInt(vars.get('gateway_udp_port'))
def timeoutMs = Integer.parseInt(vars.get('response_timeout_ms'))
def payload = vars.get('request_payload')
byte[] payloadBytes = payload.getBytes('UTF-8')
def socket = new DatagramSocket()
socket.setSoTimeout(timeoutMs)
try {
  def address = InetAddress.getByName(host)
  def requestPacket = new DatagramPacket(payloadBytes, payloadBytes.length, address, port)
  socket.send(requestPacket)
  byte[] recv = new byte[8192]
  def responsePacket = new DatagramPacket(recv, recv.length)
  socket.receive(responsePacket)
  def responseText = new String(responsePacket.getData(), 0, responsePacket.getLength(), 'UTF-8')
  prev.setSuccessful(true)
  prev.setResponseCode('200')
  prev.setResponseMessage('OK')
  prev.setResponseData(responseText, 'UTF-8')
} catch (Exception ex) {
  prev.setSuccessful(false)
  prev.setResponseCode('599')
  prev.setResponseMessage(ex.getClass().getSimpleName())
  prev.setResponseData(ex.getMessage() ?: 'UDP request failed', 'UTF-8')
} finally {
  socket.close()
}</stringProp></JSR223Sampler><hashTree><ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion" testname="UDP Response Non-Empty" enabled="true"><collectionProp name="Asserion.test_strings"><stringProp name="0">.+</stringProp></collectionProp><stringProp name="Assertion.custom_message">UDP response cannot be empty</stringProp><stringProp name="Assertion.test_field">Assertion.response_data</stringProp><boolProp name="Assertion.assume_success">false</boolProp><intProp name="Assertion.test_type">2</intProp></ResponseAssertion><hashTree/></hashTree></hashTree>

