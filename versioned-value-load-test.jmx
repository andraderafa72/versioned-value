        <hashTree>
          <JSR223Assertion guiclass="TestBeanGUI" testclass="JSR223Assertion"
                           testname="Assert 200" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="script">
def resp = prev.getResponseDataAsString()
if (!resp) { AssertionResult.setFailure(true); AssertionResult.setFailureMessage("Resposta vazia"); return }
def json = new groovy.json.JsonSlurper().parseText(resp)
def code = json.statusCode as int
if (code >= 400) {
    AssertionResult.setFailure(true)
    AssertionResult.setFailureMessage("${code} — ${json.message}")
}
            </stringProp>
          </JSR223Assertion>
          <hashTree/>
        </hashTree>

