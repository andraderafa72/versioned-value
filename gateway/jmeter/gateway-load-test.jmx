  <hashTree>
    <TestPlan guiclass="TestPlanGui" testclass="TestPlan" testname="Gateway Multi-Protocol Load Plan" enabled="true">
      <stringProp name="TestPlan.comments">Covers TCP, HTTP, gRPC and UDP with 3 fixed-duration load levels (2 minutes each), prioritizing native JMeter components.</stringProp>
      <boolProp name="TestPlan.functional_mode">false</boolProp>
