          <elementProp name="gateway_udp_port" elementType="Argument"><stringProp name="Argument.name">gateway_udp_port</stringProp><stringProp name="Argument.value">8080</stringProp><stringProp name="Argument.metadata">=</stringProp></elementProp>
          <elementProp name="service" elementType="Argument"><stringProp name="Argument.name">service</stringProp><stringProp name="Argument.value">ACCOUNT</stringProp><stringProp name="Argument.metadata">=</stringProp></elementProp>
          <elementProp name="action" elementType="Argument"><stringProp name="Argument.name">action</stringProp><stringProp name="Argument.value">POST /accounts/deposit</stringProp><stringProp name="Argument.metadata">=</stringProp></elementProp>
          <elementProp name="http_path" elementType="Argument"><stringProp name="Argument.name">http_path</stringProp><stringProp name="Argument.value">/accounts/deposit</stringProp><stringProp name="Argument.metadata">=</stringProp></elementProp>
          <elementProp name="grpc_full_method" elementType="Argument"><stringProp name="Argument.name">grpc_full_method</stringProp><stringProp name="Argument.value">br.ufrn.pdist.transport.v1.TransportGateway/Handle</stringProp><stringProp name="Argument.metadata">=</stringProp></elementProp>
