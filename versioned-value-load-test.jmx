          <stringProp name="TCPSampler.timeout">10000</stringProp>
          <stringProp name="TCPSampler.classname">TCPClientImpl</stringProp>
          <stringProp name="TCPSampler.request">{"requestId":"${__UUID()}","service":"ACCOUNT","action":"getBalance","payload":{"accountId":"tcp-${__threadNum()}-a"}}
</stringProp>
