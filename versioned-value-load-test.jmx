        <hashTree>
          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler"
                         testname="UDP — createAccount A" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="script">
def host = vars.get("HOST"); def port = vars.get("UDP_PORT") as int
def threadNum = ctx.getThreadNum()
def reqId = java.util.UUID.randomUUID().toString()
def json = """{"requestId":"${reqId}","service":"ACCOUNT","action":"createAccount","payload":{"accountId":"udp-${threadNum}-a","initialBalance":100000.00}}"""

def socket = new java.net.DatagramSocket()
socket.setSoTimeout(5000)
try {
    def addr = java.net.InetAddress.getByName(host)
    def data = json.getBytes("UTF-8")
    socket.send(new java.net.DatagramPacket(data, data.length, addr, port))
    def buf = new byte[16384]
    def respPkt = new java.net.DatagramPacket(buf, buf.length)
    socket.receive(respPkt)
    def respStr = new String(respPkt.getData(), 0, respPkt.getLength(), "UTF-8")
    def respJson = new groovy.json.JsonSlurper().parseText(respStr)
    def code = respJson.statusCode as int
    SampleResult.setResponseCode(String.valueOf(code))
    SampleResult.setResponseData(respStr, "UTF-8")
    SampleResult.setSuccessful(code == 200 || code == 409)
} catch (java.net.SocketTimeoutException e) {
    SampleResult.setResponseCode("504"); SampleResult.setSuccessful(false)
    SampleResult.setResponseData("UDP timeout", "UTF-8")
} finally {
    socket.close()
}
            </stringProp>
          </JSR223Sampler>
          <hashTree/>

          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler"
                         testname="UDP — createAccount B" enabled="true">
