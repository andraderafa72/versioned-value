<?xml version="1.0" encoding="UTF-8"?>
<!--
  PRÉ-REQUISITOS — iniciar todos os processos antes de rodar o teste:

  Gateway TCP   : java -jar gateway/target/gateway-0.0.1-SNAPSHOT.jar --protocol=TCP  --port=8080 --instanceId=gw-tcp
  Gateway HTTP  : java -jar gateway/target/gateway-0.0.1-SNAPSHOT.jar --protocol=HTTP --port=8081 --instanceId=gw-http
  Gateway gRPC  : java -jar gateway/target/gateway-0.0.1-SNAPSHOT.jar --protocol=GRPC --port=8082 --instanceId=gw-grpc
  Gateway UDP   : java -jar gateway/target/gateway-0.0.1-SNAPSHOT.jar --protocol=UDP  --port=8083 --instanceId=gw-udp

  account-service (repetir para cada protocolo/porta, ajustando --gatewayPort e --instanceId):
    java -jar account-service/target/account-service-0.0.1-SNAPSHOT.jar --protocol=TCP  --port=9080 --instanceId=acc-tcp
    java -jar account-service/target/account-service-0.0.1-SNAPSHOT.jar --protocol=HTTP --port=9081 --instanceId=acc-http
    java -jar account-service/target/account-service-0.0.1-SNAPSHOT.jar --protocol=GRPC --port=9082 --instanceId=acc-grpc
    java -jar account-service/target/account-service-0.0.1-SNAPSHOT.jar --protocol=UDP  --port=9083 --instanceId=acc-udp

  transaction-service (idem):
    java -jar transaction-service/target/transaction-service-0.0.1-SNAPSHOT.jar --protocol=TCP  --port=9180 --instanceId=tx-tcp
    java -jar transaction-service/target/transaction-service-0.0.1-SNAPSHOT.jar --protocol=HTTP --port=9181 --instanceId=tx-http
    java -jar transaction-service/target/transaction-service-0.0.1-SNAPSHOT.jar --protocol=GRPC --port=9182 --instanceId=tx-grpc
    java -jar transaction-service/target/transaction-service-0.0.1-SNAPSHOT.jar --protocol=UDP  --port=9183 --instanceId=tx-udp

  Para o Thread Group gRPC funcionar: copiar
    shared-core/target/shared-core-0.0.1-SNAPSHOT.jar
  para $JMETER_HOME/lib/ext/

  Para desabilitar um protocolo durante a apresentação: botão direito no Thread Group > Disable.
-->
<jmeterTestPlan version="1.2" properties="5.0" jmeter="5.6.3">
  <hashTree>
    <TestPlan guiclass="TestPlanGui" testclass="TestPlan"
              testname="versioned-value — 4 Protocolos" enabled="true">
      <boolProp name="TestPlan.functional_mode">false</boolProp>
      <boolProp name="TestPlan.serialize_threadgroups">false</boolProp>
      <elementProp name="TestPlan.user_defined_variables" elementType="Arguments"
                   guiclass="ArgumentsPanel" testclass="Arguments" enabled="true">
        <collectionProp name="Arguments.arguments">
          <elementProp name="HOST" elementType="Argument">
            <stringProp name="Argument.name">HOST</stringProp>
            <stringProp name="Argument.value">127.0.0.1</stringProp>
          </elementProp>
          <elementProp name="TCP_PORT" elementType="Argument">
            <stringProp name="Argument.name">TCP_PORT</stringProp>
            <stringProp name="Argument.value">8080</stringProp>
          </elementProp>
          <elementProp name="HTTP_PORT" elementType="Argument">
            <stringProp name="Argument.name">HTTP_PORT</stringProp>
            <stringProp name="Argument.value">8081</stringProp>
          </elementProp>
          <elementProp name="GRPC_PORT" elementType="Argument">
            <stringProp name="Argument.name">GRPC_PORT</stringProp>
            <stringProp name="Argument.value">8082</stringProp>
          </elementProp>
          <elementProp name="UDP_PORT" elementType="Argument">
            <stringProp name="Argument.name">UDP_PORT</stringProp>
            <stringProp name="Argument.value">8083</stringProp>
          </elementProp>
          <!-- Número de usuários: > 5 e < Knee Capacity.
               Ajustar conforme resultado da análise de carga prévia. -->
          <elementProp name="USERS" elementType="Argument">
            <stringProp name="Argument.name">USERS</stringProp>
            <stringProp name="Argument.value">10</stringProp>
          </elementProp>
          <elementProp name="RAMP_UP" elementType="Argument">
            <stringProp name="Argument.name">RAMP_UP</stringProp>
            <stringProp name="Argument.value">10</stringProp>
          </elementProp>
          <elementProp name="DURATION" elementType="Argument">
            <stringProp name="Argument.name">DURATION</stringProp>
            <stringProp name="Argument.value">300</stringProp>
          </elementProp>
        </collectionProp>
      </elementProp>
    </TestPlan>
    <hashTree>

      <!-- ================================================================ -->
      <!--                       TCP  THREAD GROUP                          -->
      <!-- ================================================================ -->
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup"
                   testname="[TCP] ${USERS} usuários" enabled="true">
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController"
                     guiclass="LoopControlPanel" testclass="LoopController" enabled="true">
          <boolProp name="LoopController.continue_forever">true</boolProp>
          <intProp name="LoopController.loops">-1</intProp>
        </elementProp>
        <stringProp name="ThreadGroup.num_threads">${USERS}</stringProp>
        <stringProp name="ThreadGroup.ramp_time">${RAMP_UP}</stringProp>
        <boolProp name="ThreadGroup.scheduler">true</boolProp>
        <stringProp name="ThreadGroup.duration">${DURATION}</stringProp>
        <stringProp name="ThreadGroup.delay">0</stringProp>
      </ThreadGroup>
      <hashTree>

        <!-- Setup: criar duas contas por thread, executado apenas uma vez -->
        <OnceOnlyController guiclass="OnceOnlyControllerGui"
                            testclass="OnceOnlyController"
                            testname="Setup — Criar contas" enabled="true"/>
        <hashTree>
          <TCPSampler guiclass="TCPSamplerUI" testclass="TCPSampler"
                      testname="TCP — createAccount A" enabled="true">
            <stringProp name="TCPSampler.server">${HOST}</stringProp>
            <stringProp name="TCPSampler.port">${TCP_PORT}</stringProp>
            <boolProp name="TCPSampler.reUseConnection">false</boolProp>
            <boolProp name="TCPSampler.closeConnection">true</boolProp>
            <stringProp name="TCPSampler.nodelay">true</stringProp>
            <stringProp name="TCPSampler.timeout">10000</stringProp>
            <stringProp name="TCPSampler.classname">TCPClientImpl</stringProp>
            <stringProp name="TCPSampler.request">{"requestId":"${__UUID()}","service":"ACCOUNT","action":"createAccount","payload":{"accountId":"tcp-${__threadNum()}-a","initialBalance":100000.00}}
</stringProp>
          </TCPSampler>
          <hashTree>
            <JSR223Assertion guiclass="TestBeanGUI" testclass="JSR223Assertion"
                             testname="Assert 200 ou 409" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="script">
def resp = prev.getResponseDataAsString()
if (!resp) return
def json = new groovy.json.JsonSlurper().parseText(resp)
def code = json.statusCode as int
if (code != 200 &amp;&amp; code != 409) {
    AssertionResult.setFailure(true)
    AssertionResult.setFailureMessage("createAccount: ${code} — ${json.message}")
}
              </stringProp>
            </JSR223Assertion>
            <hashTree/>
          </hashTree>

          <TCPSampler guiclass="TCPSamplerUI" testclass="TCPSampler"
                      testname="TCP — createAccount B" enabled="true">
            <stringProp name="TCPSampler.server">${HOST}</stringProp>
            <stringProp name="TCPSampler.port">${TCP_PORT}</stringProp>
            <boolProp name="TCPSampler.reUseConnection">false</boolProp>
            <boolProp name="TCPSampler.closeConnection">true</boolProp>
            <stringProp name="TCPSampler.nodelay">true</stringProp>
            <stringProp name="TCPSampler.timeout">10000</stringProp>
            <stringProp name="TCPSampler.classname">TCPClientImpl</stringProp>
            <stringProp name="TCPSampler.request">{"requestId":"${__UUID()}","service":"ACCOUNT","action":"createAccount","payload":{"accountId":"tcp-${__threadNum()}-b","initialBalance":100000.00}}
</stringProp>
          </TCPSampler>
          <hashTree>
            <JSR223Assertion guiclass="TestBeanGUI" testclass="JSR223Assertion"
                             testname="Assert 200 ou 409" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="script">
def resp = prev.getResponseDataAsString()
if (!resp) return
def json = new groovy.json.JsonSlurper().parseText(resp)
def code = json.statusCode as int
if (code != 200 &amp;&amp; code != 409) {
    AssertionResult.setFailure(true)
    AssertionResult.setFailureMessage("createAccount: ${code} — ${json.message}")
}
              </stringProp>
            </JSR223Assertion>
            <hashTree/>
          </hashTree>
        </hashTree>

        <!-- getBalance -->
        <TCPSampler guiclass="TCPSamplerUI" testclass="TCPSampler"
                    testname="TCP — getBalance" enabled="true">
          <stringProp name="TCPSampler.server">${HOST}</stringProp>
